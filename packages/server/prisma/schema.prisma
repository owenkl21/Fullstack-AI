generator client {
  provider   = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "mysql"
}

enum WaterType {
  FRESHWATER
  SALTWATER
  BRACKISH
  OTHER
}

enum GearType {
  ROD
  REEL
  BAIT
  LURE
  LINE
  HOOK
  WEIGHTS
}

enum FeedPostType {
  CATCH
  SITE
}

enum FeedScope {
  GLOBAL
  NEARBY
}

model User {
  id           String        @id @default(cuid())
  clerkId      String        @unique
  email        String        @unique
  username     String        @unique
  displayName  String
  bio          String?
  avatarUrl    String?
  catches      Catch[]
  sites        FishingSite[]
  reviews      Review[]
  comments     Comment[]
  uploaded     Image[]       @relation("UploadedImages")
  following    Follow[]      @relation("FollowerRelation")
  followers    Follow[]      @relation("FollowingRelation")
  catchLikes   CatchLike[]
  siteLikes    SiteLike[]
  gear         Gear[]
  feedPosts    FeedPost[]
  feedLikes    FeedLike[]
  feedComments FeedComment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  @@map("users")
}

model FishingSite {
  id          String      @id @default(cuid())
  createdById String
  createdBy   User        @relation(fields: [createdById], references: [id])
  name        String
  description String?
  latitude    Float?
  longitude   Float?
  waterType   WaterType?
  accessNotes String?
  likeCount   Int         @default(0)
  reviewCount Int         @default(0)
  catchCount  Int         @default(0)
  catches     Catch[]
  reviews     Review[]
  likes       SiteLike[]
  images      SiteImage[]
  feedPosts   FeedPost[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  @@index([createdById])
}

model Gear {
  id          String   @id @default(cuid())
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  name        String
  brand       String
  type        GearType
  imageUrl    String?
  catches     Catch[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdById])
  @@map("gear")
}

model Species {
  id             String   @id @default(cuid())
  commonName     String
  scientificName String?
  aliases        Json?
  regionTags     Json?
  catches        Catch[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Catch {
  id           String       @id @default(cuid())
  createdById  String
  createdBy    User         @relation(fields: [createdById], references: [id])
  siteId       String?
  site         FishingSite? @relation(fields: [siteId], references: [id], onDelete: SetNull)
  speciesId    String?
  species      Species?     @relation(fields: [speciesId], references: [id], onDelete: SetNull)
  gears        Gear[]
  title        String
  notes        String?
  caughtAt     DateTime
  weight       Float?
  length       Float?
  count        Int          @default(1)
  weather      String?
  waterTemp    Float?
  depth        Float?
  likeCount    Int          @default(0)
  commentCount Int          @default(0)
  comments     Comment[]
  likes        CatchLike[]
  images       CatchImage[]
  feedPosts    FeedPost[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?

  @@index([createdById, caughtAt(sort: Desc)])
  @@index([siteId, caughtAt(sort: Desc)])
}

model Review {
  id        String      @id @default(cuid())
  siteId    String
  site      FishingSite @relation(fields: [siteId], references: [id])
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  rating    Int
  body      String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  deletedAt DateTime?

  @@unique([siteId, userId])
  @@index([siteId, createdAt(sort: Desc)])
}

model Comment {
  id        String    @id @default(cuid())
  catchId   String
  catch     Catch     @relation(fields: [catchId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([catchId, createdAt(sort: Asc)])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  follower    User     @relation("FollowerRelation", fields: [followerId], references: [id])
  following   User     @relation("FollowingRelation", fields: [followingId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model CatchLike {
  id        String   @id @default(cuid())
  catchId   String
  catch     Catch    @relation(fields: [catchId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([catchId, userId])
}

model SiteLike {
  id        String      @id @default(cuid())
  siteId    String
  site      FishingSite @relation(fields: [siteId], references: [id])
  userId    String
  user      User        @relation(fields: [userId], references: [id])
  createdAt DateTime    @default(now())

  @@unique([siteId, userId])
}

model Image {
  id           String       @id @default(cuid())
  url          String
  storageKey   String       @unique
  uploadedById String
  uploadedBy   User         @relation("UploadedImages", fields: [uploadedById], references: [id])
  catchLinks   CatchImage[]
  siteLinks    SiteImage[]
  createdAt    DateTime     @default(now())
}

model CatchImage {
  id       String @id @default(cuid())
  catchId  String
  catch    Catch  @relation(fields: [catchId], references: [id])
  imageId  String
  image    Image  @relation(fields: [imageId], references: [id])
  position Int    @default(0)

  @@unique([catchId, imageId])
}

model SiteImage {
  id       String      @id @default(cuid())
  siteId   String
  site     FishingSite @relation(fields: [siteId], references: [id])
  imageId  String
  image    Image       @relation(fields: [imageId], references: [id])
  position Int         @default(0)

  @@unique([siteId, imageId])
}

model FeedPost {
  id           String        @id @default(cuid())
  authorId     String
  author       User          @relation(fields: [authorId], references: [id])
  type         FeedPostType
  scope        FeedScope     @default(GLOBAL)
  content      String?
  catchId      String?
  catch        Catch?        @relation(fields: [catchId], references: [id], onDelete: SetNull)
  siteId       String?
  site         FishingSite?  @relation(fields: [siteId], references: [id], onDelete: SetNull)
  latitude     Float?
  longitude    Float?
  likeCount    Int           @default(0)
  commentCount Int           @default(0)
  likes        FeedLike[]
  comments     FeedComment[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  @@index([createdAt(sort: Desc)])
  @@index([scope, createdAt(sort: Desc)])
  @@index([authorId, createdAt(sort: Desc)])
}

model FeedLike {
  id        String   @id @default(cuid())
  postId    String
  post      FeedPost @relation(fields: [postId], references: [id])
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([postId, userId])
}

model FeedComment {
  id        String    @id @default(cuid())
  postId    String
  post      FeedPost  @relation(fields: [postId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  body      String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([postId, createdAt(sort: Desc)])
}

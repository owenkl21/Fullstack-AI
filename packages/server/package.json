{
   "name": "server",
   "module": "index.ts",
   "type": "module",
   "private": true,
   "scripts": {
      "start": "bun run prisma:db:push && bun run prisma:generate && bun run index.ts",
      "dev": "bun run prisma:db:push && bun run prisma:generate && bun run --watch index.ts",
      "prisma:generate": "prisma generate",
      "prisma:seed": "bun run prisma/seed.ts",
      "prisma:db:create": "bun run prisma/create-database.ts",
      "prisma:db:push": "prisma db push",
      "prisma:setup": "bun run prisma:db:create && bun run prisma:db:push && bun run prisma:seed"
   },
   "prisma": {
      "seed": "bun run prisma/seed.ts"
   },
   "devDependencies": {
      "@types/bun": "latest",
      "@types/express": "^5.0.6",
      "prisma": "^7.4.2"
   },
   "peerDependencies": {
      "typescript": "^5"
   },
   "dependencies": {
      "@aws-sdk/client-s3": "^3.1004.0",
      "@aws-sdk/s3-request-presigner": "^3.1004.0",
      "@clerk/express": "^2.0.1",
      "@prisma/adapter-mariadb": "^7.4.2",
      "@prisma/client": "^7.4.2",
      "axios": "^1.13.6",
      "dotenv": "^17.3.1",
      "express": "^5.2.1",
      "mysql2": "^3.19.0",
      "openai": "^6.25.0",
      "zod": "^4.3.6"
   }
}
